# ========================================================
#  VTuber Song Queue -- Configuration
#  Copy this file to .env and fill in your values.
#  Secrets and credentials live here.
#  Behaviour settings (thresholds, tabs, etc.) -> server/config.js
# ========================================================

# --- Application Mode ---
# local  = local exe / EventSub WebSocket / public client + device code
# server = hosted server / EventSub Webhook / confidential client
APP_MODE=local


# --- Twitch App ---
# From https://dev.twitch.tv/console/apps -> your app -> Manage

TWITCH_CLIENT_ID=your_client_id_here
TWITCH_CLIENT_SECRET=


# --- Twitch Channel ---
# Your numeric broadcaster ID (not your username)
# Get it at: https://streamweasels.com/tools/convert-twitch-username-to-user-id

TWITCH_BROADCASTER_ID=your_numeric_user_id_here
TWITCH_EVENTSUB_TRANSPORT=websocket

# Only required in server mode.
TWITCH_WEBHOOK_SECRET=

# Required in local mode.
# The setup wizard can fill these for you after Twitch device authorization.
TWITCH_USER_ACCESS_TOKEN=
TWITCH_USER_REFRESH_TOKEN=
TWITCH_USER_TOKEN_EXPIRES_AT=


# --- Twitch Channel Points Rewards ---
# Create these rewards in your Twitch Dashboard -> Viewer Rewards -> Channel Points
# Get reward IDs via: GET helix/channel_points/custom_rewards

# # Song Request reward (requires viewer text input)
TWITCH_REWARD_ID=your_song_request_reward_id_here

# * Random Song reward (no text input needed)
TWITCH_RANDOM_REWARD_ID=your_random_reward_id_here


# --- Google Sheets ---
# Sheet ID is the long string in your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit

# Your song list sheet
GOOGLE_SHEET_ID=your_sheet_id_here

# Column headers in your song list sheet (must match row 1 exactly)
SHEET_SONG_COLUMN=title
SHEET_ARTIST_COLUMN=artist

# A separate blank sheet for request history tracking
# Share it with your service account email (Editor access)
HISTORY_SHEET_ID=your_history_sheet_id_here


# --- Server ---
PORT=3000

# Public HTTPS URL where Twitch can reach this server
# Only required when APP_MODE=server
# Use ngrok for local streaming: https://your-id.ngrok-free.app
# Update this every stream (unless you have a static ngrok domain)
PUBLIC_URL=


# --- Random Song Behaviour ---
# pure     = truly random pick from all eligible songs
# weighted = favor songs that haven't been played recently (recommended)
RANDOM_PICK_MODE=weighted
